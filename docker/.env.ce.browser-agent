# LiveContext CE - opt-in env file for the BROWSER AGENT (agent_browse).
#
# The browser agent is OFF by default in CE because it needs a heavy
# Chromium + browser-use container (~1 GB image, +2 GB shm). This file turns
# it on in one shot - both halves are required and must stay coupled:
#   COMPOSE_PROFILES=browser-agent  -> starts the `websearch` container
#   WEBSEARCH_ENABLED=true          -> loads BrowserAgentModule in the monolith
# Setting only one leaves the feature broken (a running container the
# orchestrator never calls, or a loaded module with no container to call).
#
# Usage (from the repo root):
#   docker compose --env-file docker/.env.ce.browser-agent up -d
#
# Model: the agent node picks the model (default gemini 3.1 flash). The
# monolith injects the install's Google/Gemini key into each browse job, so
# set GEMINI_API_KEY (or configure a Google credential in the app) for it to
# run. Live screencast needs WEBSEARCH_CDP_JWT_SECRET on both services; without
# it the panel still shows the captured last-page screenshot.

COMPOSE_PROFILES=browser-agent
WEBSEARCH_ENABLED=true
