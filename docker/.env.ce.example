# ══════════════════════════════════════════════════════════════════════
# LiveContext CE - Environment Configuration
# Copy this file: cp .env.ce.example .env
# ══════════════════════════════════════════════════════════════════════

# === LLM API Keys (at least one required) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === Optional LLM Providers ===
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# === Social Login (leave empty to disable) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Credential Encryption (auto-generated if left empty) ===
# On first boot, LiveContext generates unique encryption keys and persists
# them to a Docker volume. You only need to set these if you want to
# provide your own keys (e.g., migrating from another instance).
# WARNING: Changing these after credentials have been stored will make
# existing encrypted credentials unreadable.
# CREDENTIAL_ENCRYPTION_PASSWORD=
# CREDENTIAL_ENCRYPTION_SALT=

# === Database (CHANGE before exposing the deployment beyond localhost) ===
POSTGRES_PASSWORD=postgres

# === Object Storage (MinIO - CHANGE BOTH before exposing beyond localhost) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === LiveContext Cloud (optional) ===
# CE consumes the cloud marketplace in read/acquire mode out of the box
# (MARKETPLACE_MODE=remote). To accept signed cloud catalog/LLM bundles, set the
# public trusted key below; with none configured, CE safely rejects every bundle.
# CATALOG_BUNDLE_TRUSTED_KEYS=

# === Bridge (Claude Code CLI - optional) ===
# Uses your Claude subscription instead of API credits.
# Requires: Claude Code CLI installed + bridge running locally
#   cd mcp/bridge && node server.mjs
# BRIDGE_ENABLED=true
# BRIDGE_URL=http://host.docker.internal:8093
