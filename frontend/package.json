{
  "name": "api-marketplace-frontend",
  "private": true,
  "version": "0.1.3",
  "license": "BUSL-1.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "rm -rf .next node_modules/.cache .swc",
    "clean:win": "if exist .next rmdir /s /q .next && if exist node_modules\\.cache rmdir /s /q node_modules\\.cache && if exist .swc rmdir /s /q .swc",
    "contracts:validate": "node ../shared/contracts/scripts/validate.js",
    "contracts:validate:strict": "node ../shared/contracts/scripts/validate.js --strict",
    "contracts:generate:ts": "node ../shared/contracts/scripts/generate-ts.js",
    "contracts:generate": "npm run contracts:generate:ts",
    "contracts:check": "npm run contracts:validate && npm run contracts:generate:ts",
    "contracts:test": "node ../shared/contracts/scripts/contract-tests.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "npm run contracts:validate && npm run contracts:test && vitest run --testNamePattern='contract'"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.87.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^10.1.3",
    "lucide-react": "^0.540.0",
    "next": "16.2.6",
    "next-intl": "^4.6.1",
    "oidc-client-ts": "^3.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-oidc-context": "^3.2.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-window": "^2.2.7",
    "reactflow": "^11.11.4",
    "recharts": "^3.7.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.12",
    "typescript": "5.9.2",
    "vitest": "4.1.8"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5.10"
  }
