  "plan": {
    "triggers": [
      {
        "id": "trigger-parent",
        "type": "manual",
        "label": "Start the risky work",
        "position": {
          "x": 120,
          "y": 260
        },
        "params": {}
      },
      {
        "id": "00000000-0000-0000-0000-000000000000",
        "type": "error",
        "label": "On parent failure",
        "position": {
          "x": 120,
          "y": 700
        },
        "params": {
          "workflowName": "templates.workflow.errorHandler.noParentSelected"
        }
      }
    ],
    "mcps": [],
    "cores": [
      {
        "id": "core-work",
        "type": "transform",
        "label": "Do the work",
        "position": {
          "x": 500,
          "y": 260
        },
        "transform": {
          "mappings": [
            {
              "label": "attempted",
              "expression": "templates.workflow.errorHandler.attempted"
            }
          ]
        }
      },
      {
        "id": "core-fail",
        "type": "stop_on_error",
        "label": "Fail on purpose",
        "position": {
          "x": 880,
          "y": 260
        },
        "stopOnError": {
          "errorMessage": "templates.workflow.errorHandler.stopMessage",
          "errorCode": "ERR_DEMO"
        }
      },
      {
        "id": "core-read",
        "type": "transform",
        "label": "Read failure",
        "position": {
          "x": 500,
          "y": 700
        },
        "transform": {
          "mappings": [
            {
              "label": "failed_workflow",
              "expression": "{{trigger:on_parent_failure.output.parentWorkflowId}}"
            },
            {
              "label": "failed_run",
              "expression": "{{trigger:on_parent_failure.output.parentRunId}}"
            },
            {
              "label": "reason",
              "expression": "{{trigger:on_parent_failure.output.errorMessage}}"
            },
            {
              "label": "failed_step_count",
              "expression": "{{trigger:on_parent_failure.output.failedSteps}}"
            }
          ]
        }
      }
    ],
    "notes": [
