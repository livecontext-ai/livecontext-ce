<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                  https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!-- Minimal persistence-unit used by MessageSearchRepositoryIT to spin up
         a bare JPA layer for native-query tests. NO entities are mapped - the
         repository under test only uses native SQL via em.createNativeQuery().
         Other integration tests use Spring's @SpringBootTest path. -->
    <persistence-unit name="test-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

    <!-- ConversationSummaryColdRepositoryIT - maps ONLY Conversation+Message
         (the association closure the ConversationRepository proxy needs) so
         the real Spring Data repository can be built over a bare EM without
         booting a Spring context (the @DataJpaTest slice trips over the main
         RedisConfig vs IntegrationTestConfig bean overrides). Hibernate
         creates the two tables on a fresh PG testcontainer at EMF init. -->
    <persistence-unit name="summary-cold-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.apimarketplace.conversation.entity.Conversation</class>
        <class>com.apimarketplace.conversation.entity.Message</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

</persistence>
