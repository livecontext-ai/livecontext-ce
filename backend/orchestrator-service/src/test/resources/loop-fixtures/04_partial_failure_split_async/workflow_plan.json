{
  "id": "fixture-04-partial-failure-split-async",
  "triggers": [
    {
      "id": "t1",
      "type": "manual",
      "label": "Start",
      "position": { "x": 100, "y": 200 }
    }
  ],
  "mcps": [
    {
      "id": "mock/fetch_emails",
      "type": "mcp",
      "label": "Fetch Emails",
      "position": { "x": 300, "y": 200 },
      "params": {}
    },
    {
      "id": "mock/apply_label",
      "type": "mcp",
      "label": "Apply Label",
      "position": { "x": 900, "y": 200 },
      "params": {
        "messageId": "{{item.id}}",
        "label": "{{agent:classify_email.output.selected_category_label}}"
      }
    }
  ],
  "tables": [],
  "agents": [
    {
      "id": "a1",
      "type": "classify",
      "label": "Classify Email",
      "provider": "anthropic",
      "model": "claude-3-haiku",
      "classifyParams": "{{item.subject}} {{item.body}}",
      "classifyCategories": [
        { "id": "cat-0", "label": "Inbox" },
        { "id": "cat-1", "label": "Spam" },
        { "id": "cat-2", "label": "Archive" }
      ],
      "position": { "x": 700, "y": 200 }
    }
  ],
  "cores": [
    {
      "id": "c1",
      "type": "split",
      "label": "Per Email",
      "position": { "x": 500, "y": 200 },
      "list": "{{mcp:fetch_emails.output.items}}",
      "maxItems": 30,
      "splitStrategy": "continue-anyway"
    },
    {
      "id": "c2",
      "type": "merge",
      "label": "Aggregate",
      "position": { "x": 1100, "y": 200 }
    }
  ],
  "edges": [
    { "from": "trigger:start", "to": "mcp:fetch_emails" },
    { "from": "mcp:fetch_emails", "to": "core:per_email" },
    { "from": "core:per_email", "to": "agent:classify_email" },
    { "from": "agent:classify_email", "to": "mcp:apply_label" },
    { "from": "mcp:apply_label", "to": "core:aggregate" }
  ],
  "notes": [
    {
      "id": "n1",
      "type": "note",
      "label": "Partial-failure-split-async fixture",
      "text": "Fetch emits 30 items. Async classify barrier seals 26 items as COMPLETED, 4 items as FAILED (Google 429 simulated by MockToolsGateway). Merge must resolve with 26 successful per-item results AND 4 propagated failures. Reference: memory project_partial_failure_split_async_fix (2026-04-29 implemented v6).",
      "color": "#fef3c7",
      "borderColor": "#f59e0b",
      "textColor": "#92400e",
      "width": 320,
      "height": 120,
      "position": { "x": 50, "y": 50 }
    }
  ],
  "interfaces": []
}
